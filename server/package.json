    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "imap": "^0.8.19",
    "knex": "^3.1.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
